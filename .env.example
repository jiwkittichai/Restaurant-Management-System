# MySQL / Prisma
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=restaurant_system
MYSQL_USER=user
MYSQL_PASSWORD=password
MYSQL_PORT=3306
DATABASE_URL="mysql://user:password@127.0.0.1:3306/restaurant_system"

# phpMyAdmin
PMA_HOST=db
PMA_PORT=3306
PHPMYADMIN_PORT=8080

# MinIO server
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# MinIO client used by the Next.js app
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
NEXT_PUBLIC_MINIO_PUBLIC_URL=http://127.0.0.1:9000/products

# Initial owner account used by npm run db:seed
SEED_OWNER_USERNAME=admin
SEED_OWNER_PASSWORD=admin888